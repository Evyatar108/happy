# Copy this file to `keystore.properties` (gitignored) and fill in the
# real values for the production release keystore. The real file lives
# only on the maintainer's PC and in the OneDrive backup at
# `C:\Users\evmitran\OneDrive\secrets\happy-app-release\`.
#
# Use forward slashes on Windows — Java Properties parses backslashes
# as escape characters. Without `RELEASE_STORE_FILE` set, the production
# build deliberately fails (see android/app/build.gradle).

RELEASE_STORE_FILE=D:/secrets/happy-app-release.keystore
RELEASE_STORE_PASSWORD=<from 1Password / OneDrive README>
RELEASE_KEY_ALIAS=happy-app
RELEASE_KEY_PASSWORD=<from 1Password / OneDrive README>
