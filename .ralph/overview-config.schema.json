{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codexu.local/schemas/overview-config.schema.json",
  "title": "Codexu Overview Ralph Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "dataFile": { "type": "string" },
    "ralphRoot": { "type": "string" },
    "ralphSubdirs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "jobs": { "type": "string" },
        "jobGroups": { "type": "string" },
        "brainstorms": { "type": "string" }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sidecarJs": { "type": "string" },
        "sidecarJson": { "type": "string" },
        "snapshot": { "type": "string" },
        "activity": { "type": "string" },
        "activityBackup": { "type": "string" },
        "dataJson": { "type": "string" },
        "snapshotSchema": { "type": "string" },
        "tasksIndex": { "type": "string" },
        "recommendationsJson": { "type": "string" },
        "dependencyGraphJson": { "type": "string" },
        "activityMaxLines": { "type": "integer", "minimum": 1, "default": 1000 }
      }
    },
    "recommendations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "weights": { "type": "object" },
        "topN": { "type": "integer", "minimum": 1 }
      }
    },
    "lockFile": { "type": "string" },
    "watcher": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ignored": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}

