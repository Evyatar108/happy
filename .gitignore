# Development planning notes (keep local, don't commit)
notes/
docs/notes/
# ralphex progress logs
progress*.txt

# OpenCode trace output (script is committed, output is not)
docs/competition/opencode/traces/

# Ralph orchestration plugin state.
#
# Track everything under .ralph/jobs/, .ralph/job-groups/, .ralph/brainstorms/
# (plan, PRD, notepad, review outputs, job state, ralph.sh batch logs — all
# reviewable alongside the code each cycle produced; batch logs in particular
# are valuable forensic trails when debugging an agent's behavior).
#
# Only ignore per-job worktrees — those are multi-GB full repo clones
# with node_modules and would balloon the git history immediately.
.ralph/**/worktree/

# happy-server runtime log directory (rich pino logs from the running service).
# Contents are time-stamped per-process; not source-controlled.
packages/happy-server/logs/

# Workspace junctions (per-machine; created by `mklink /J`) — never tracked.
# Each developer creates these locally to navigate the multi-repo workspace.
# See plans/codexu-roadmap.md → "Active session pickup" → step 9.
# Note: /codex is now a git submodule (gim-home/codex), no longer a per-machine junction.
/ralph
/options-mode
/inspirations/

# scratch tooling (upstream)
.cdp-scripts/
happy-workspaces/
docs/validation/boox-screenshots-*/
.test-output/
