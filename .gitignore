# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts
/ios
/android
/packages/happy-app/ios

# packages/happy-app/android/ is partially tracked: build.gradle,
# settings.gradle, gradle/, gradlew*, app/build.gradle, app/proguard-rules.pro,
# app/google-services.json, app/debug.keystore, and app/src/ all carry
# load-bearing fork customizations (env-driven applicationId, signing
# wiring, the @expo/cli wrapper pointer, Kotlin sources under
# com/slopus/happy/dev/). Without these in git, a fresh clone cannot
# reproduce a release. Build outputs and machine-specific files stay
# ignored — see .agents/skills/happy-app-playstore-release/SKILL.md.
packages/happy-app/android/build/
packages/happy-app/android/app/build/
packages/happy-app/android/.gradle/
packages/happy-app/android/.cxx/
packages/happy-app/android/app/.cxx/
packages/happy-app/android/local.properties
packages/happy-app/android/keystore.properties

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env
.env.production

# typescript
*.tsbuildinfo

.claude/settings.local.json
.claude/*.lock
.claude/worktrees/
.plan

CLAUDE.local.md
CLAUDE.md
.claude/CLAUDE.md

.dev/worktree/*

# Local dev environments
.environments/
environments/data/

# Development planning notes (keep local, don't commit)
notes/
docs/notes/
# ralphex progress logs
progress*.txt

# OpenCode trace output (script is committed, output is not)
docs/competition/opencode/traces/

# Ralph orchestration scratch — brainstorm staging, job worktrees, debug screenshots.
# Existing tracked artifacts under `.ralph/brainstorms/codex-fork-extension-strategy/`
# stay tracked (gitignore doesn't affect already-tracked files); only future entries
# are ignored.
.ralph/

# happy-server runtime log directory (rich pino logs from the running service).
# Contents are time-stamped per-process; not source-controlled.
packages/happy-server/logs/
.ralph/reviews/

# Workspace junctions (per-machine; created by `mklink /J`) — never tracked.
# Each developer creates these locally to navigate the multi-repo workspace.
# See plans/codexu-roadmap.md → "Active session pickup" → step 9.
/codex
/ralph
/options-mode
/inspirations/

